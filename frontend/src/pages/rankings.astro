---
import BaseLayout from '../layouts/BaseLayout.astro';

const API_URL = 'http://localhost:3001/api';
let rankings = [];
let error = '';

try {
  const response = await fetch(`${API_URL}/performances/rankings`);
  if (response.ok) {
    rankings = await response.json();
  } else {
    error = 'Error fetching rankings';
  }
} catch (e) {
  error = 'Backend not available';
}
---

<BaseLayout title="Rankings">
  <main>
    <div class="container">
      <h1>🏅 Top 10 jugadores</h1>

      {error && <p class="error-box">⚠️ {error}</p>}

      {!error && (
        <table class="table">
          <thead>
            <tr>
              <th>Jugador</th>
              <th>Goles</th>
              <th>Asistencias</th>
              <th>Partidos</th>
            </tr>
          </thead>
          <tbody>
            {rankings.map((player: any) => (
              <tr>
                <td>{player.player_name}</td>
                <td>{player.total_goals}</td>
                <td>{player.total_assists}</td>
                <td>{player.appearances}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .container { max-width: 900px; margin: 0 auto; padding: 2rem 1rem; }
  .error-box { background: #fee; border: 1px solid #fcc; padding: 1rem; color: #c33; margin-bottom: 1rem; }
  .table { width: 100%; border-collapse: collapse; }
  .table th, .table td { padding: 0.75rem; border-bottom: 1px solid #ddd; text-align: left; }
  .table th { background: #f5f5f5; }
</style>
